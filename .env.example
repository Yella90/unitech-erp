SESSION_SECRET=change_this_in_production
JWT_SECRET=change_this_jwt_secret
SUPERADMIN_EMAIL=superadmin@unitech.local
SUPERADMIN_PASSWORD=Unitech@2026
PORT=3000
DISPLAY_TIMEZONE=Africa/Bamako

# Desktop/offline-first mode
DB_CLIENT=sqlite
SQLITE_PATH=
DB_MINIMAL_BOOTSTRAP=0
SYNC_WORKER_INTERVAL_MS=30000
ELECTRON_APP_URL=

# Supabase central sync (IPv4 pooler session mode: 5432)
PGHOST=aws-1-eu-central-1.pooler.supabase.com
PGPORT=5432
PG_FAMILY=4
PGUSER=postgres.sagvtnbbbdrfuoqxnplf
PGPASSWORD="#L70401780ls"
PGDATABASE=postgres
PGSSL=true
DATABASE_URL=postgresql://postgres.sagvtnbbbdrfuoqxnplf:%23L70401780ls@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
CENTRAL_DATABASE_URL=postgresql://postgres.sagvtnbbbdrfuoqxnplf:%23L70401780ls@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
CENTRAL_PGSSL=true
CENTRAL_PG_CONNECT_TIMEOUT_MS=10000

# OCR
OCR_LANG=fra+eng
OCR_PSM=6

# Desktop auto-update
# GitHub Releases:
# ELECTRON_UPDATE_PROVIDER=github
# GH_OWNER=Yella90
# GH_REPO=unitech-erp
#
# Custom HTTP endpoint:
# ELECTRON_UPDATE_PROVIDER=generic
# ELECTRON_UPDATE_URL=https://your-domain.example/download/desktop/windows/update/
ELECTRON_UPDATE_PROVIDER=github
ELECTRON_UPDATE_URL=
GH_OWNER=Yella90
GH_REPO=unitech-erp
GH_USE_LATEST_RELEASE=true
GH_RELEASE_TAG=
GH_WINDOWS_ARTIFACT=
GH_MAC_ARTIFACT=
DESKTOP_WINDOWS_INSTALLER_URL=
DESKTOP_MAC_INSTALLER_URL=
# GH_TOKEN=ghp_xxx   # for publish only (CI/local shell), never commit a real token

