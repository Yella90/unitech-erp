<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('../../partials/head') %>
  <title>Modules</title>
</head>
<body class="bg-gray-100 min-h-screen p-6">
  <div class="max-w-4xl mx-auto bg-white rounded-xl shadow p-6">
    <h1 class="text-2xl font-bold mb-4">Modules fonctionnels</h1>
    <div class="grid md:grid-cols-2 gap-3">
      <% modules.forEach((item, idx) => { %>
        <a href="/modules/<%= item.slug %>" class="border rounded p-3 hover:bg-gray-50">
          <span class="font-semibold"><%= idx + 1 %>. <%= item.title %></span>
        </a>
      <% }) %>
    </div>
    <a href="/" class="inline-block mt-4 text-blue-600 hover:underline">Retour accueil</a>
  </div>
</body>
</html>
