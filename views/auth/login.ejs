<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UNITECH ERP - Connexion</title>
  <link href="/css/output.css" rel="stylesheet">
  <script defer src="/js/back-navigation.js"></script>
</head>
<body class="min-h-screen bg-[#F3F4F6]" data-back-fallback="/vitrine">
  <div class="relative min-h-screen overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[#1E3A8A] via-[#1E40AF] to-[#0F172A] opacity-95"></div>
    <div class="absolute -right-20 -top-20 h-80 w-80 rounded-full bg-[#F97316]/20 blur-3xl"></div>
    <div class="absolute -left-20 bottom-0 h-80 w-80 rounded-full bg-white/10 blur-3xl"></div>

    <main class="relative z-10 mx-auto flex min-h-screen max-w-md items-center px-4 py-8">
      <section class="w-full rounded-2xl bg-white p-6 shadow-2xl">
        <div class="mb-6 text-center">
          <div class="mx-auto mb-3 grid h-14 w-14 place-items-center rounded-xl bg-[#1E3A8A] text-white font-bold">U</div>
          <h1 class="text-2xl font-bold text-slate-900">UNITECH ERP</h1>
          <p class="text-sm text-slate-500">Connexion securisee multi-role</p>
        </div>
        <% const sync = realtimeSyncStatus || {}; %>
        <% const isSqliteMode = sync.mode === "sqlite"; %>
        <% const loginDbLabel = !isSqliteMode ? "Mode: PostgreSQL (serveur)" : (!sync.centralConfigured ? "Mode: SQLite local uniquement" : (sync.connected ? "Mode: SQLite + PostgreSQL connecte" : "Mode: SQLite local (PostgreSQL hors ligne)")); %>
        <div class="mb-3 rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-700"><%= loginDbLabel %></div>

        <% if (error) { %>
          <div class="mb-3 rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700"><%= error %></div>
        <% } %>
        <% if (warning) { %>
          <div class="mb-3 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-700"><%= warning %></div>
        <% } %>
        <% if (success) { %>
          <div class="mb-3 rounded-xl border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm text-emerald-700"><%= success %></div>
        <% } %>

        <form method="POST" action="/auth/login" class="space-y-4">
          <label class="block">
            <span class="mb-1 block text-sm font-medium text-slate-700">Email</span>
            <div class="flex items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-3 transition focus-within:border-[#1E3A8A] focus-within:bg-white">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8m-18 8h18a2 2 0 002-2V8a2 2 0 00-2-2H3a2 2 0 00-2 2v6a2 2 0 002 2z"/></svg>
              <input type="email" name="email" class="w-full bg-transparent py-2.5 text-sm outline-none" required>
            </div>
          </label>

          <label class="block">
            <span class="mb-1 block text-sm font-medium text-slate-700">Mot de passe</span>
            <div class="flex items-center gap-2 rounded-xl border border-slate-200 bg-slate-50 px-3 transition focus-within:border-[#1E3A8A] focus-within:bg-white">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2h-1V9a5 5 0 00-10 0v2H6a2 2 0 00-2 2v6a2 2 0 002 2zm3-10V9a3 3 0 016 0v2H9z"/></svg>
              <input type="password" name="password" class="w-full bg-transparent py-2.5 text-sm outline-none" required>
            </div>
          </label>

          <button type="submit" class="w-full rounded-xl bg-[#1E3A8A] py-2.5 text-sm font-semibold text-white shadow transition hover:bg-[#172f70]">
            Se connecter
          </button>
        </form>

        <a href="/auth/register-school" class="mt-5 block text-center text-sm font-medium text-[#F97316] hover:underline">Creer une ecole</a>
        <div class="mt-4 grid grid-cols-1 gap-2 sm:grid-cols-2">
          <a href="/vitrine" class="rounded-xl border border-slate-200 px-3 py-2 text-center text-xs font-semibold text-slate-700 hover:bg-slate-50">
            Voir la vitrine ERP
          </a>
          <a href="/entreprise" class="rounded-xl border border-slate-200 px-3 py-2 text-center text-xs font-semibold text-slate-700 hover:bg-slate-50">
            Page entreprise
          </a>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
