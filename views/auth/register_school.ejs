<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Inscription Ecole</title>
  <link href="/css/output.css" rel="stylesheet">
</head>
<body class="min-h-screen bg-gray-100 p-4">
  <main class="max-w-3xl mx-auto bg-white rounded-xl shadow p-6">
    <h1 class="text-2xl font-bold mb-2">Inscription nouvelle ecole</h1>
    <p class="text-gray-500 mb-4">Creation automatique du compte administrateur.</p>

    <% if (error) { %>
      <div class="mb-3 bg-red-100 border border-red-300 text-red-700 rounded p-3"><%= error %></div>
    <% } %>

    <form method="POST" action="/auth/register-school" class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium mb-1">Nom ecole</label>
        <input type="text" name="schoolName" class="w-full border rounded p-2" required>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Email ecole</label>
        <input type="email" name="schoolEmail" class="w-full border rounded p-2" required>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Telephone</label>
        <input type="text" name="schoolPhone" class="w-full border rounded p-2">
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Adresse</label>
        <input type="text" name="schoolAddress" class="w-full border rounded p-2">
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Plan</label>
        <select name="subscriptionPlan" class="w-full border rounded p-2">
          <% plans.forEach((plan) => { %>
            <option value="<%= plan.code %>"><%= plan.name %> - <%= plan.price_monthly %> FCFA/mois - <%= Number(plan.price_annual || 0) %> FCFA/an</option>
          <% }) %>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Facturation</label>
        <select name="billingCycle" class="w-full border rounded p-2">
          <option value="monthly">Mensuelle</option>
          <option value="annual">Annuelle (reduction)</option>
        </select>
      </div>

      <div class="md:col-span-2 border-t pt-4 mt-2">
        <h2 class="font-semibold mb-2">Administrateur ecole</h2>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Nom complet admin</label>
        <input type="text" name="adminName" class="w-full border rounded p-2" required>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Email admin</label>
        <input type="email" name="adminEmail" class="w-full border rounded p-2" required>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Mot de passe admin</label>
        <input type="password" name="adminPassword" class="w-full border rounded p-2" minlength="8" required>
      </div>

      <div class="md:col-span-2 flex justify-between items-center mt-4">
        <a href="/auth/login" class="text-blue-600 hover:underline">Retour connexion</a>
        <button type="submit" class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">Creer mon espace</button>
      </div>
    </form>
  </main>
</body>
</html>
