  <script>
    (function () {
      const loader = document.getElementById("landing-loader");
      window.addEventListener("load", function () {
        if (loader) loader.classList.add("hidden");
      });

      const nav = document.getElementById("smart-nav");
      const onScroll = () => {
        if (!nav) return;
        if (window.scrollY > 10) nav.classList.add("scrolled");
        else nav.classList.remove("scrolled");
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      const revealEls = Array.from(document.querySelectorAll(".reveal"));
      const revealObserver = new IntersectionObserver((entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const delay = Number(entry.target.getAttribute("data-reveal-delay") || 0);
          setTimeout(() => entry.target.classList.add("show"), delay);
          obs.unobserve(entry.target);
        });
      }, { threshold: 0.15 });
      revealEls.forEach((el) => revealObserver.observe(el));

      const counterEls = Array.from(document.querySelectorAll("[data-counter-target]"));
      const runCounter = (el) => {
        const target = Number(el.getAttribute("data-counter-target") || 0);
        const suffix = el.getAttribute("data-counter-suffix") || "+";
        const start = performance.now();
        const duration = 1300;
        const tick = (now) => {
          const ratio = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - ratio, 3);
          const value = Math.round(target * eased);
          el.textContent = value.toLocaleString("fr-FR") + suffix;
          if (ratio < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      };
      const counterObserver = new IntersectionObserver((entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          runCounter(entry.target);
          obs.unobserve(entry.target);
        });
      }, { threshold: 0.5 });
      counterEls.forEach((el) => counterObserver.observe(el));

      const ctaButtons = Array.from(document.querySelectorAll(".cta-btn"));
      ctaButtons.forEach((btn) => {
        btn.addEventListener("mouseenter", (ev) => {
          const rect = btn.getBoundingClientRect();
          btn.style.setProperty("--rx", (ev.clientX - rect.left) + "px");
          btn.style.setProperty("--ry", (ev.clientY - rect.top) + "px");
          btn.classList.remove("ripple");
          void btn.offsetWidth;
          btn.classList.add("ripple");
          setTimeout(() => btn.classList.remove("ripple"), 550);
        });
      });

      if (typeof window.UNITECH_TRACK_PUBLIC_VISIT === "function") {
        window.UNITECH_TRACK_PUBLIC_VISIT("/vitrine");
      }
    })();
  </script>
