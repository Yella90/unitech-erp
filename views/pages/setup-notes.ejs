<section class="space-y-5">
  <div class="card-shell p-5">
    <h2 class="text-base font-semibold">Assistant setup - Etape 3/3: Notes</h2>
    <p class="mt-1 text-sm text-slate-500">Ajoutez les notes via tableau dynamique, import Excel/CSV ou OCR photo.</p>
  </div>

  <div class="card-shell p-5">
    <h3 class="font-semibold">Saisie dynamique</h3>
    <div class="mt-3 grid gap-3 md:grid-cols-5">
      <div>
        <label class="form-label">Classe</label>
        <select class="form-input" id="setup-classe" name="classe">
          <option value="">Selectionner</option>
          <% (classes || []).forEach((c) => { %><option value="<%= c.nom %>"><%= c.nom %></option><% }) %>
        </select>
      </div>
      <div>
        <label class="form-label">Matiere</label>
        <select class="form-input" id="setup-matiere" name="matiere">
          <option value="">Selectionner</option>
          <% (matieres || []).forEach((m) => { %><option value="<%= m.nom %>"><%= m.nom %></option><% }) %>
        </select>
      </div>
      <div>
        <label class="form-label">Trimestre</label>
        <select class="form-input" id="setup-trimestre" name="trimestre"><option value="1">T1</option><option value="2">T2</option><option value="3">T3</option></select>
      </div>
      <div>
        <label class="form-label">Type note</label>
        <select class="form-input" id="setup-note-type" name="note_type"><option value="devoir">Devoir</option><option value="composition">Composition</option></select>
      </div>
      <div>
        <label class="form-label">Annee</label>
        <input class="form-input" id="setup-annee" name="annee" value="<%= activeSchoolYear || '' %>" />
      </div>
    </div>
    <div class="mt-3">
      <button type="button" id="load-eleves-btn" class="btn btn-secondary">Charger eleves</button>
    </div>

    <form method="POST" action="/setup/notes/dynamic" class="mt-4">
      <input type="hidden" name="classe" id="payload-classe" />
      <input type="hidden" name="matiere" id="payload-matiere" />
      <input type="hidden" name="trimestre" id="payload-trimestre" />
      <input type="hidden" name="note_type" id="payload-note-type" />
      <input type="hidden" name="annee" id="payload-annee" />
      <input type="hidden" name="rows_json" id="rows-json" />
      <div class="overflow-x-auto">
        <table class="w-full text-sm" id="notes-table">
          <thead><tr class="border-b border-slate-200 text-slate-500"><th class="px-3 py-2 text-left">Matricule</th><th class="px-3 py-2 text-left">Nom</th><th class="px-3 py-2 text-left">Note</th></tr></thead>
          <tbody id="notes-tbody"><tr><td colspan="3" class="px-3 py-3 text-slate-500">Chargez une classe pour commencer.</td></tr></tbody>
        </table>
      </div>
      <button type="submit" class="btn btn-primary mt-4">Enregistrer notes</button>
    </form>
  </div>

  <div class="grid gap-5 lg:grid-cols-2">
    <div class="card-shell p-5">
      <h3 class="font-semibold">Import Excel / CSV</h3>
      <p class="mt-1 text-xs text-slate-500">Modele: Matricule | Note</p>
      <form method="POST" action="/setup/notes/import/excel" enctype="multipart/form-data" class="mt-3 grid gap-3">
        <div class="grid gap-3 md:grid-cols-2">
          <select class="form-input" name="classe" required><option value="">Classe</option><% (classes || []).forEach((c) => { %><option value="<%= c.nom %>"><%= c.nom %></option><% }) %></select>
          <select class="form-input" name="matiere" required><option value="">Matiere</option><% (matieres || []).forEach((m) => { %><option value="<%= m.nom %>"><%= m.nom %></option><% }) %></select>
          <select class="form-input" name="trimestre" required><option value="1">T1</option><option value="2">T2</option><option value="3">T3</option></select>
          <select class="form-input" name="note_type"><option value="devoir">Devoir</option><option value="composition">Composition</option></select>
          <input class="form-input" name="annee" value="<%= activeSchoolYear || '' %>" placeholder="Annee" required />
          <input type="file" class="form-input" name="notes_file" accept=".xlsx,.xls,.csv" required />
        </div>
        <button class="btn btn-primary" type="submit">Importer notes Excel</button>
      </form>
    </div>

    <div class="card-shell p-5">
      <h3 class="font-semibold">Import photo OCR</h3>
      <p class="mt-1 text-xs text-slate-500">Format OCR attendu: Matricule;Note (une ligne par eleve)</p>
      <form method="POST" action="/setup/notes/import/photo/preview" enctype="multipart/form-data" class="mt-3 grid gap-3">
        <div class="grid gap-3 md:grid-cols-2">
          <select class="form-input" name="classe" required><option value="">Classe</option><% (classes || []).forEach((c) => { %><option value="<%= c.nom %>"><%= c.nom %></option><% }) %></select>
          <select class="form-input" name="matiere" required><option value="">Matiere</option><% (matieres || []).forEach((m) => { %><option value="<%= m.nom %>"><%= m.nom %></option><% }) %></select>
          <select class="form-input" name="trimestre" required><option value="1">T1</option><option value="2">T2</option><option value="3">T3</option></select>
          <select class="form-input" name="note_type"><option value="devoir">Devoir</option><option value="composition">Composition</option></select>
          <input class="form-input" name="annee" value="<%= activeSchoolYear || '' %>" placeholder="Annee" required />
          <input type="file" class="form-input" name="notes_photo" accept="image/*" required />
        </div>
        <button class="btn btn-secondary" type="submit">Apercu + correction OCR</button>
      </form>
    </div>
  </div>

  <% if (ocrRawText) { %>
    <div class="card-shell p-5">
      <h3 class="font-semibold">Texte OCR brut</h3>
      <textarea class="form-input mt-3 h-36" readonly><%= ocrRawText %></textarea>
    </div>
  <% } %>

  <% if (previewNoteErrors && previewNoteErrors.length) { %>
    <div class="card-shell p-5">
      <h3 class="font-semibold text-rose-700">Avertissements OCR</h3>
      <ul class="mt-2 list-disc pl-5 text-sm text-rose-700">
        <% previewNoteErrors.forEach((e) => { %><li><%= e %></li><% }) %>
      </ul>
    </div>
  <% } %>

  <% if (previewNoteRows && previewNoteRows.length) { %>
    <div class="card-shell p-5">
      <h3 class="font-semibold">Correction manuelle avant insertion (<%= previewNoteRows.length %> lignes)</h3>
      <div class="mt-3 overflow-x-auto">
        <table class="w-full text-sm" id="notes-preview-table">
          <thead>
            <tr class="border-b border-slate-200 text-slate-500">
              <th class="px-3 py-2 text-left">Matricule</th>
              <th class="px-3 py-2 text-left">Note</th>
            </tr>
          </thead>
          <tbody>
            <% previewNoteRows.forEach((r) => { %>
              <tr class="border-b border-slate-100">
                <td class="px-3 py-2"><input class="form-input note-preview-matricule" value="<%= r.matricule || '' %>" /></td>
                <td class="px-3 py-2"><input type="number" step="0.01" min="0" max="20" class="form-input note-preview-note" value="<%= Number(r.note || 0) %>" /></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <form method="POST" action="/setup/notes/import/commit" id="notes-preview-form" class="mt-4">
        <input type="hidden" name="classe" value="<%= (noteImportMeta && noteImportMeta.classe) || '' %>" />
        <input type="hidden" name="matiere" value="<%= (noteImportMeta && noteImportMeta.matiere) || '' %>" />
        <input type="hidden" name="trimestre" value="<%= (noteImportMeta && noteImportMeta.trimestre) || '1' %>" />
        <input type="hidden" name="note_type" value="<%= (noteImportMeta && noteImportMeta.note_type) || 'devoir' %>" />
        <input type="hidden" name="annee" value="<%= (noteImportMeta && noteImportMeta.annee) || '' %>" />
        <input type="hidden" name="preview_rows_json" id="notes-preview-json" value="" />
        <button class="btn btn-primary" type="submit">Confirmer import OCR notes</button>
      </form>
    </div>
  <% } %>
</section>

<script>
  (function () {
    const loadBtn = document.getElementById("load-eleves-btn");
    const classeInput = document.getElementById("setup-classe");
    const matiereInput = document.getElementById("setup-matiere");
    const trimestreInput = document.getElementById("setup-trimestre");
    const noteTypeInput = document.getElementById("setup-note-type");
    const anneeInput = document.getElementById("setup-annee");
    const tbody = document.getElementById("notes-tbody");
    const rowsJson = document.getElementById("rows-json");

    function syncPayload() {
      document.getElementById("payload-classe").value = classeInput.value || "";
      document.getElementById("payload-matiere").value = matiereInput.value || "";
      document.getElementById("payload-trimestre").value = trimestreInput.value || "";
      document.getElementById("payload-note-type").value = noteTypeInput.value || "";
      document.getElementById("payload-annee").value = anneeInput.value || "";
    }

    async function loadEleves() {
      const classe = classeInput.value;
      syncPayload();
      if (!classe) return;
      const resp = await fetch(`/setup/notes/eleves?classe=${encodeURIComponent(classe)}`);
      const json = await resp.json();
      if (!json.ok) return;
      const rows = json.rows || [];
      if (!rows.length) {
        tbody.innerHTML = '<tr><td colspan="3" class="px-3 py-3 text-slate-500">Aucun eleve dans cette classe.</td></tr>';
        return;
      }
      tbody.innerHTML = rows.map((r) => (
        `<tr class="border-b border-slate-100">
          <td class="px-3 py-2">${r.matricule}</td>
          <td class="px-3 py-2">${(r.nom || "")} ${(r.prenom || "")}</td>
          <td class="px-3 py-2"><input type="number" step="0.01" min="0" max="20" class="form-input note-input" data-matricule="${r.matricule}" /></td>
        </tr>`
      )).join("");
      bindNoteInputs();
    }

    function bindNoteInputs() {
      const inputs = Array.from(document.querySelectorAll(".note-input"));
      const updateRowsJson = () => {
        const rows = inputs
          .map((el) => ({ matricule: el.getAttribute("data-matricule"), note: Number(el.value) }))
          .filter((r) => Number.isFinite(r.note));
        rowsJson.value = JSON.stringify(rows);
      };
      inputs.forEach((input) => input.addEventListener("input", updateRowsJson));
      updateRowsJson();
    }

    if (loadBtn) {
      loadBtn.addEventListener("click", loadEleves);
    }
    [classeInput, matiereInput, trimestreInput, noteTypeInput, anneeInput].forEach((el) => {
      if (el) el.addEventListener("change", syncPayload);
    });
    syncPayload();
  })();

  (function () {
    const form = document.getElementById("notes-preview-form");
    if (!form) return;
    form.addEventListener("submit", function () {
      const rows = Array.from(document.querySelectorAll("#notes-preview-table tbody tr")).map((tr) => ({
        matricule: (tr.querySelector(".note-preview-matricule") || {}).value || "",
        note: Number((tr.querySelector(".note-preview-note") || {}).value)
      }));
      document.getElementById("notes-preview-json").value = JSON.stringify(rows);
    });
  })();
</script>
