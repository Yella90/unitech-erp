<% const d = details || {}; %>
<% const q = d.queue || {}; %>
<section class="space-y-6">
  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <article class="rounded-xl border border-slate-200 bg-white p-4">
      <p class="text-xs font-semibold uppercase text-slate-500">Mode</p>
      <p class="mt-2 text-base font-semibold text-slate-900"><%= d.mode === 'postgres' ? 'PostgreSQL (serveur)' : 'SQLite local' %></p>
      <p class="mt-1 text-xs text-slate-500"><%= d.connected ? 'Connecte au central' : 'Central hors ligne/non configure' %></p>
    </article>
    <article class="rounded-xl border border-slate-200 bg-white p-4">
      <p class="text-xs font-semibold uppercase text-slate-500">En attente</p>
      <p class="mt-2 text-2xl font-bold text-amber-700"><%= Number(q.pending || 0) %></p>
      <p class="mt-1 text-xs text-slate-500">Plus ancien: <%= fmtDateTime(q.oldestPendingAt) %></p>
    </article>
    <article class="rounded-xl border border-slate-200 bg-white p-4">
      <p class="text-xs font-semibold uppercase text-slate-500">Echecs</p>
      <p class="mt-2 text-2xl font-bold text-rose-700"><%= Number(q.failed || 0) %></p>
      <p class="mt-1 text-xs text-slate-500">Derniere erreur: <%= fmtDateTime(d.lastErrorAt) %></p>
    </article>
    <article class="rounded-xl border border-slate-200 bg-white p-4">
      <p class="text-xs font-semibold uppercase text-slate-500">Synchronises</p>
      <p class="mt-2 text-2xl font-bold text-emerald-700"><%= Number(q.synced || 0) %></p>
      <p class="mt-1 text-xs text-slate-500">Dernier succes: <%= fmtDateTime(d.lastSuccessAt) %></p>
    </article>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-4">
    <h2 class="text-base font-semibold text-slate-900">Tables surveillees</h2>
    <p class="mt-2 text-sm text-slate-600"><%= (d.tables || []).join(', ') || '-' %></p>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-4">
    <h2 class="text-base font-semibold text-slate-900">Derniere date pull par table</h2>
    <div class="mt-3 overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead>
          <tr class="border-b border-slate-200 text-left text-slate-500">
            <th class="py-2 pr-4">Table</th>
            <th class="py-2 pr-4">last_pulled_at</th>
          </tr>
        </thead>
        <tbody>
          <% (d.pullState || []).forEach((row) => { %>
            <tr class="border-b border-slate-100">
              <td class="py-2 pr-4 font-medium text-slate-800"><%= row.table_name %></td>
              <td class="py-2 pr-4 text-slate-600"><%= fmtDateTime(row.last_pulled_at) %></td>
            </tr>
          <% }) %>
          <% if (!d.pullState || !d.pullState.length) { %>
            <tr><td class="py-3 text-slate-500" colspan="2">Aucune synchronisation pull enregistree.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="rounded-xl border border-slate-200 bg-white p-4">
    <h2 class="text-base font-semibold text-slate-900">Erreurs recentes</h2>
    <div class="mt-3 overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead>
          <tr class="border-b border-slate-200 text-left text-slate-500">
            <th class="py-2 pr-4">Date</th>
            <th class="py-2 pr-4">Table</th>
            <th class="py-2 pr-4">Operation</th>
            <th class="py-2 pr-4">Retry</th>
            <th class="py-2 pr-4">Erreur</th>
          </tr>
        </thead>
        <tbody>
          <% (d.recentErrors || []).forEach((row) => { %>
            <tr class="border-b border-slate-100 align-top">
              <td class="py-2 pr-4 text-slate-600"><%= fmtDateTime(row.updated_at) %></td>
              <td class="py-2 pr-4 font-medium text-slate-800"><%= row.table_name %></td>
              <td class="py-2 pr-4 text-slate-600"><%= row.operation %></td>
              <td class="py-2 pr-4 text-slate-600"><%= Number(row.retry_count || 0) %></td>
              <td class="py-2 pr-4 text-rose-700"><%= row.last_error || '-' %></td>
            </tr>
          <% }) %>
          <% if (!d.recentErrors || !d.recentErrors.length) { %>
            <tr><td class="py-3 text-slate-500" colspan="5">Aucune erreur recente.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</section>
