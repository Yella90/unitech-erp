<section class="space-y-5">
  <div class="card-shell p-5">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div class="space-y-1">
        <h2 class="text-base font-semibold text-slate-900">Bibliotheque des matieres</h2>
        <p class="text-sm text-slate-600">
          Ajoutez et maintenez les matieres utilisees pour les affectations, les emplois du temps et les notes.
        </p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-right">
        <p class="text-xs uppercase tracking-wide text-slate-500">Total matieres</p>
        <p class="text-2xl font-bold text-slate-900"><%= (matieres || []).length %></p>
      </div>
    </div>
  </div>

  <div class="grid gap-5 lg:grid-cols-[1.1fr_1.9fr]">
    <div class="card-shell p-5">
      <h3 class="text-sm font-semibold text-slate-900">Nouvelle matiere</h3>
      <p class="mt-1 text-xs text-slate-500">Le coefficient sera applique automatiquement dans les calculs de moyenne.</p>

      <form method="POST" action="/matieres" class="mt-4 space-y-3">
        <div>
          <label class="form-label" for="nom">Nom de la matiere</label>
          <input id="nom" class="form-input" name="nom" placeholder="Ex: Mathematiques" required />
        </div>
        <div>
          <label class="form-label" for="coefficient">Coefficient</label>
          <input id="coefficient" class="form-input" type="number" step="0.1" min="0.1" name="coefficient" placeholder="Ex: 2" required />
        </div>
        <button class="btn btn-primary w-full sm:w-auto" type="submit">Ajouter la matiere</button>
      </form>
    </div>

    <div class="card-shell overflow-hidden">
      <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4">
        <h3 class="text-sm font-semibold text-slate-900">Liste des matieres</h3>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600"><%= (matieres || []).length %> element(s)</span>
      </div>

      <div class="overflow-x-auto">
        <table class="w-full min-w-[520px] text-sm">
          <thead class="bg-slate-50 text-slate-600">
            <tr>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide">#</th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide">Matiere</th>
              <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide">Coefficient</th>
              <th class="px-5 py-3 text-right text-xs font-semibold uppercase tracking-wide">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% (matieres || []).forEach((m, index) => { %>
              <tr class="hover:bg-slate-50/80">
                <td class="px-5 py-3 text-slate-500"><%= index + 1 %></td>
                <td class="px-5 py-3 font-medium text-slate-800"><%= m.nom %></td>
                <td class="px-5 py-3">
                  <span class="rounded-lg bg-blue-50 px-2.5 py-1 text-xs font-semibold text-blue-700"><%= Number(m.coefficient || 0) %></span>
                </td>
                <td class="px-5 py-3 text-right">
                  <form method="POST" action="/matieres/delete/<%= m.id %>" class="inline" data-confirm="Supprimer la matiere <%= m.nom %> ?">
                    <button class="btn btn-danger btn-sm" type="submit">Supprimer</button>
                  </form>
                </td>
              </tr>
            <% }) %>

            <% if (!matieres || !matieres.length) { %>
              <tr>
                <td colspan="4" class="px-5 py-12 text-center">
                  <p class="text-sm font-medium text-slate-600">Aucune matiere enregistree.</p>
                  <p class="mt-1 text-xs text-slate-500">Ajoutez votre premiere matiere via le formulaire a gauche.</p>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
