<section class="space-y-5">
  <div class="card-shell p-5">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <h2 class="text-base font-semibold">Historique complet eleve</h2>
      <a href="/eleves/liste" class="btn btn-secondary">Retour liste eleves</a>
    </div>
    <div class="mt-4 rounded-xl border border-slate-200 bg-slate-50 p-4 text-sm space-y-1">
      <p><span class="font-semibold">Nom:</span> <%= history.student.nom %> <%= history.student.prenom %></p>
      <p><span class="font-semibold">UUID:</span> <%= history.student.uuid %></p>
      <p><span class="font-semibold">Date naissance:</span> <%= history.student.date_naissance || '-' %></p>
      <p><span class="font-semibold">Sexe:</span> <%= history.student.sexe || '-' %></p>
    </div>
  </div>

  <% (history.enrollments || []).forEach((en) => { %>
    <div class="card-shell p-5">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <h3 class="text-base font-semibold">
          <%= en.ecole_name %> - <%= en.classe_name || 'Classe non definie' %>
        </h3>
        <span class="badge <%= en.statut === 'actif' ? 'badge-ok' : 'badge-warn' %>"><%= en.statut %></span>
      </div>
      <p class="mt-2 text-sm text-slate-600">
        Entree: <%= en.date_entree || '-' %> | Sortie: <%= en.date_sortie || '-' %>
      </p>

      <div class="mt-4 grid gap-4 lg:grid-cols-2">
        <div class="rounded-xl border border-slate-200 p-4">
          <h4 class="font-semibold text-sm">Moyennes annuelles</h4>
          <div class="mt-3 overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-slate-600">
                  <th class="px-2 py-2 text-left">Annee</th>
                  <th class="px-2 py-2 text-left">Moyenne</th>
                </tr>
              </thead>
              <tbody>
                <% if (en.yearlyAverages && en.yearlyAverages.length) { %>
                  <% en.yearlyAverages.forEach((y) => { %>
                    <tr class="border-b border-slate-100">
                      <td class="px-2 py-2"><%= y.school_year %></td>
                      <td class="px-2 py-2"><%= y.moyenne_annuelle %>/20</td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="2" class="px-2 py-4 text-slate-400">Aucune moyenne annuelle.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="rounded-xl border border-slate-200 p-4">
          <h4 class="font-semibold text-sm">Notes detaillees (lecture seule)</h4>
          <div class="mt-3 max-h-64 overflow-y-auto overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-slate-200 text-slate-600">
                  <th class="px-2 py-2 text-left">Annee</th>
                  <th class="px-2 py-2 text-left">Trimestre</th>
                  <th class="px-2 py-2 text-left">Matiere</th>
                  <th class="px-2 py-2 text-left">Note</th>
                </tr>
              </thead>
              <tbody>
                <% if (en.notes && en.notes.length) { %>
                  <% en.notes.forEach((n) => { %>
                    <tr class="border-b border-slate-100">
                      <td class="px-2 py-2"><%= n.school_year || '-' %></td>
                      <td class="px-2 py-2"><%= n.trimestre %></td>
                      <td class="px-2 py-2"><%= n.matiere_name || '-' %></td>
                      <td class="px-2 py-2"><%= n.note %>/20</td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr>
                    <td colspan="4" class="px-2 py-4 text-slate-400">Aucune note sur cette inscription.</td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</section>
