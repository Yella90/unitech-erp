<section class="space-y-5">
  <div class="card-shell p-5">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <div>
        <h2 class="text-base font-semibold">Notifications d'activite</h2>
        <p class="text-sm text-slate-500">Demandes de transfert, transferts traites et retards de paiement du debut de mois.</p>
      </div>
      <form method="POST" action="/notifications/read-all">
        <button class="btn btn-secondary" type="submit">Tout marquer lu</button>
      </form>
    </div>

    <form method="GET" action="/notifications" class="mt-4 grid gap-3 md:grid-cols-6">
      <div>
        <label class="form-label">Statut notif</label>
        <select class="form-input" name="status">
          <option value="" <%= !notificationFilters || !notificationFilters.status ? 'selected' : '' %>>Toutes</option>
          <option value="unread" <%= notificationFilters && notificationFilters.status === 'unread' ? 'selected' : '' %>>Non lues</option>
          <option value="read" <%= notificationFilters && notificationFilters.status === 'read' ? 'selected' : '' %>>Lues</option>
        </select>
      </div>
      <div>
        <label class="form-label">Type notif</label>
        <select class="form-input" name="type">
          <option value="" <%= !notificationFilters || !notificationFilters.type ? 'selected' : '' %>>Tous</option>
          <option value="transfer_requested" <%= notificationFilters && notificationFilters.type === 'transfer_requested' ? 'selected' : '' %>>Demande transfert</option>
          <option value="transfer_accepted" <%= notificationFilters && notificationFilters.type === 'transfer_accepted' ? 'selected' : '' %>>Transfert accepte</option>
          <option value="transfer_rejected" <%= notificationFilters && notificationFilters.type === 'transfer_rejected' ? 'selected' : '' %>>Transfert refuse</option>
          <option value="retard_eleve" <%= notificationFilters && notificationFilters.type === 'retard_eleve' ? 'selected' : '' %>>Retard eleve</option>
          <option value="retard_personnel" <%= notificationFilters && notificationFilters.type === 'retard_personnel' ? 'selected' : '' %>>Retard personnel</option>
        </select>
      </div>
      <div>
        <label class="form-label">Matricule</label>
        <input class="form-input" name="matricule" value="<%= query && query.matricule ? query.matricule : '' %>" />
      </div>
      <div>
        <label class="form-label">Classe</label>
        <select class="form-input" name="classe">
          <option value="">Toutes</option>
          <% (classes || []).forEach((c) => { %>
            <option value="<%= c.nom %>" <%= query && query.classe === c.nom ? 'selected' : '' %>><%= c.nom %></option>
          <% }) %>
        </select>
      </div>
      <div class="flex items-end gap-2">
        <label class="inline-flex items-center gap-2 text-sm">
          <input type="checkbox" name="retard" value="1" <%= query && query.retard ? 'checked' : '' %> />
          Uniquement en retard
        </label>
      </div>
      <div class="flex items-end gap-2">
        <button class="btn btn-secondary" type="submit">Filtrer</button>
        <a class="btn btn-primary" href="/notifications/export?<%= exportQuery || '' %>">Exporter PDF</a>
      </div>
    </form>
    <p class="mt-3 text-xs text-slate-500">Notifications non lues: <strong><%= Number(unreadCount || 0) %></strong></p>
  </div>

  <div class="card-shell overflow-hidden">
    <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-900">Flux des notifications</h2>
    </div>
    <div class="overflow-x-auto">
      <table class="w-full min-w-[900px] text-sm">
        <thead class="bg-slate-50 text-slate-600">
          <tr>
            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide">Date</th>
            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide">Type</th>
            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide">Titre</th>
            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide">Message</th>
            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide">Statut</th>
            <th class="px-5 py-3 text-left text-xs font-semibold uppercase tracking-wide">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% if (notifications && notifications.length) { %>
            <% notifications.forEach((n) => { %>
              <tr>
                <td class="px-5 py-3"><%= fmtDateTime(n.created_at) %></td>
                <td class="px-5 py-3"><%= n.type %></td>
                <td class="px-5 py-3 font-medium"><%= n.title %></td>
                <td class="px-5 py-3"><%= n.message %></td>
                <td class="px-5 py-3">
                  <span class="badge <%= Number(n.is_read) === 1 ? 'badge-ok' : 'badge-warn' %>">
                    <%= Number(n.is_read) === 1 ? 'Lue' : 'Non lue' %>
                  </span>
                </td>
                <td class="px-5 py-3">
                  <% if (Number(n.is_read) === 0) { %>
                    <form method="POST" action="/notifications/<%= n.id %>/read">
                      <button class="btn btn-secondary btn-sm" type="submit">Marquer lu</button>
                    </form>
                  <% } else { %>
                    <span class="text-slate-400 text-xs">-</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="6" class="px-5 py-10 text-center text-slate-400">Aucune notification.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <p class="text-xs text-slate-500">Mois ecoules depuis la date de rentree: <strong><%= mois || 0 %></strong></p>

  <%- include('../partials/table', {
    tableTitle: 'Retards eleves',
    headers: ['Matricule', 'Nom', 'Classe', 'Mensuel', 'Total paye', 'Total du', 'Reste'],
    rows: eleves || [],
    rowPartial: '../partials/rows/notifications-row',
    emptyText: 'Aucun eleve a afficher.'
  }) %>

  <%- include('../partials/table', {
    tableTitle: 'Retards personnel et enseignants',
    headers: ['Type', 'Matricule', 'Nom', 'Poste', 'Paiement', 'Mensuel prevu', 'Total paye', 'Total du', 'Reste'],
    rows: personnels || [],
    rowPartial: '../partials/rows/notifications-staff-row',
    emptyText: 'Aucun personnel actif a afficher.'
  }) %>
</section>
