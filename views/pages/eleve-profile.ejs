<section class="space-y-5">
  <div class="card-shell p-5">
    <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
      <div class="space-y-3">
        <div class="flex items-center gap-3">
          <div class="h-12 w-12 rounded-xl bg-[#1E3A8A] p-2 shadow-sm">
            <svg viewBox="0 0 64 64" class="h-full w-full" role="img" aria-label="UNITECH logo">
              <circle cx="32" cy="32" r="18" fill="none" stroke="#F97316" stroke-width="3" />
              <circle cx="32" cy="32" r="6" fill="#F97316" />
              <path d="M32 8v6M32 50v6M8 32h6M50 32h6M14 18l4 4M46 46l4 4M14 46l4-4M46 18l4-4" stroke="#F97316" stroke-width="3" stroke-linecap="round"/>
              <path d="M22 32h8l4-6 8 12" fill="none" stroke="#F97316" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="leading-tight">
            <p class="text-[10px] uppercase tracking-[0.35em] text-slate-400">Tech solutions</p>
            <p class="text-xl font-semibold tracking-[0.18em] text-[#1E3A8A]">UNI<span class="text-[#F97316]">TECH</span></p>
          </div>
        </div>
        <h2 class="text-lg font-semibold"><%= eleve.nom %> <%= eleve.prenom %></h2>
        <p class="text-sm text-slate-500">Matricule: <strong><%= eleve.matricule %></strong></p>
        <p class="text-sm text-slate-500">Classe: <strong><%= eleve.classe || '-' %></strong></p>
      </div>
      <div class="flex gap-2">
        <a href="/eleves/edit/<%= eleve.matricule %>" class="btn btn-secondary">Modifier</a>
        <a href="/eleves/liste" class="btn btn-primary">Retour liste</a>
      </div>
    </div>
  </div>

  <div class="grid gap-5 lg:grid-cols-2">
    <div class="card-shell p-5 space-y-3">
      <h3 class="font-semibold">Informations eleve</h3>
      <p class="text-sm text-slate-600">Date naissance: <strong><%= eleve.dateNaissance || '-' %></strong></p>
      <p class="text-sm text-slate-600">Parent: <strong><%= eleve.nomParent || '-' %></strong></p>
      <p class="text-sm text-slate-600">Telephone parent: <strong><%= eleve.telparent || '-' %></strong></p>
      <p class="text-sm text-slate-600">Statut: <strong><%= eleve.statut || 'actif' %></strong></p>
      <p class="text-sm text-slate-600">Total verse: <strong><%= Number(eleve.caise || 0) %> FCFA</strong></p>
    </div>

    <div class="card-shell p-5">
      <h3 class="font-semibold mb-3">Documents</h3>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <p class="text-xs font-medium text-slate-500 mb-2">Photo de profil</p>
          <% if (eleve.photo_profil) { %>
            <img src="<%= eleve.photo_profil %>" alt="Photo profil" class="h-40 w-full rounded-lg border border-slate-200 object-cover" />
          <% } else { %>
            <div class="h-40 w-full rounded-lg border border-dashed border-slate-300 grid place-items-center text-xs text-slate-500">Aucune photo</div>
          <% } %>
        </div>
        <div>
          <p class="text-xs font-medium text-slate-500 mb-2">Acte de naissance</p>
          <% if (eleve.photo_acte_naissance) { %>
            <% if ((eleve.photo_acte_naissance || '').toLowerCase().includes('.pdf')) { %>
              <a href="<%= eleve.photo_acte_naissance %>" target="_blank" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm text-indigo-700">
                Voir le PDF
              </a>
            <% } else { %>
              <img src="<%= eleve.photo_acte_naissance %>" alt="Acte de naissance" class="h-40 w-full rounded-lg border border-slate-200 object-cover" />
            <% } %>
          <% } else { %>
            <div class="h-40 w-full rounded-lg border border-dashed border-slate-300 grid place-items-center text-xs text-slate-500">Aucun document</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>

  <div class="card-shell p-5">
    <h3 class="font-semibold mb-3">Synthese des notes</h3>
    <% if (!notesSummary || !notesSummary.length) { %>
      <p class="text-sm text-slate-500">Aucune note disponible.</p>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 text-slate-600">
              <th class="px-3 py-2 text-left">Matiere</th>
              <th class="px-3 py-2 text-left">Trimestre</th>
              <th class="px-3 py-2 text-left">Annee</th>
              <th class="px-3 py-2 text-left">Moyenne</th>
            </tr>
          </thead>
          <tbody>
            <% notesSummary.forEach((row) => { %>
              <tr class="border-b border-slate-100">
                <td class="px-3 py-2"><%= row.matiere %></td>
                <td class="px-3 py-2"><%= row.trimestre %></td>
                <td class="px-3 py-2"><%= row.annee || '-' %></td>
                <td class="px-3 py-2 font-medium"><%= Number(row.moyenne || 0).toFixed(2) %> / 20</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <div class="card-shell p-5">
    <h3 class="font-semibold mb-3">Historique des notes</h3>
    <% if (!notes || !notes.length) { %>
      <p class="text-sm text-slate-500">Aucune note enregistree.</p>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 text-slate-600">
              <th class="px-3 py-2 text-left">Date</th>
              <th class="px-3 py-2 text-left">Matiere</th>
              <th class="px-3 py-2 text-left">Type</th>
              <th class="px-3 py-2 text-left">Trimestre</th>
              <th class="px-3 py-2 text-left">Annee</th>
              <th class="px-3 py-2 text-left">Note</th>
            </tr>
          </thead>
          <tbody>
            <% notes.forEach((row) => { %>
              <tr class="border-b border-slate-100">
                <td class="px-3 py-2"><%= fmtDateTime(row.created_at) %></td>
                <td class="px-3 py-2"><%= row.matiere %></td>
                <td class="px-3 py-2"><%= row.note_type || '-' %></td>
                <td class="px-3 py-2"><%= row.trimestre %></td>
                <td class="px-3 py-2"><%= row.annee || '-' %></td>
                <td class="px-3 py-2 font-medium"><%= Number(row.note || 0).toFixed(2) %> / 20</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</section>
