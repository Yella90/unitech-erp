<div id="app-modal" class="pointer-events-none fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/50 p-4">
  <div class="w-full max-w-md rounded-2xl bg-white p-6 shadow-2xl">
    <h3 class="text-lg font-semibold text-slate-900">Confirmation</h3>
    <p id="modal-message" class="mt-2 text-sm text-slate-600">Confirmer cette action ?</p>
    <div class="mt-5 flex justify-end gap-2">
      <button id="modal-cancel" class="btn btn-secondary" type="button">Annuler</button>
      <button id="modal-confirm" class="btn btn-danger" type="button">Confirmer</button>
    </div>
  </div>
</div>
