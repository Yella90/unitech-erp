<tr class="transition hover:bg-slate-50/70">
  <td class="px-5 py-3"><span class="inline-flex min-w-8 justify-center rounded-full bg-slate-900 px-2 py-1 text-xs font-semibold text-white"><%= row.rang %></span></td>
  <td class="px-5 py-3"><%= row.matricule %></td>
  <td class="px-5 py-3"><%= row.nom %> <%= row.prenom %></td>
  <td class="px-5 py-3 font-semibold"><%= row.moyenne_generale %>/20</td>
  <td class="px-5 py-3"><%= row.mention %></td>
  <td class="px-5 py-3"><%= row.appreciation || '-' %></td>
  <td class="px-5 py-3">
    <span class="badge <%= row.decision === 'Admis' ? 'badge-ok' : 'badge-warn' %>"><%= row.decision %></span>
  </td>
</tr>
