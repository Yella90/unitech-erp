<!DOCTYPE html>
<html lang="fr">
<head>
  <%- include('head') %>
  <title><%= pageTitle || 'ERP SaaS' %></title>
</head>
<% const _backFallback = (currentUser && currentUser.role === "superadmin") ? "/admin/dashboard" : "/dashboard"; %>
<body class="bg-slate-50 text-slate-800 antialiased" data-back-fallback="<%= _backFallback %>">
  <div id="global-loader" class="pointer-events-none fixed inset-0 z-[70] hidden items-center justify-center bg-white/70 backdrop-blur-sm">
    <div class="loader-ring"></div>
  </div>

  <div class="min-h-screen lg:grid lg:grid-cols-[18rem_1fr]">
    <%- include('sidebar', { activeNav }) %>

    <div class="lg:col-start-2 flex min-h-screen flex-col">
      <%- include('navbar', { pageTitle }) %>
      <main class="flex-1 overflow-y-auto p-4 sm:p-6 lg:p-8 space-y-6">
        <%- include(contentPartial) %>
      </main>
    </div>
  </div>

  <%- include('toast') %>
  <%- include('modal') %>
  <%- include('footer') %>
</body>
</html>
