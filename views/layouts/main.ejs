<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle || "UNITECH ERP" %></title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link href="/css/output.css" rel="stylesheet">
  <script defer src="/js/back-navigation.js"></script>
</head>
<body class="min-h-screen bg-[#F3F4F6] text-slate-800" data-back-fallback="<%= (currentUser && currentUser.role === 'superadmin') ? '/admin/dashboard' : '/dashboard' %>">
  <header class="sticky top-0 z-30 border-b border-slate-200 bg-white">
    <div class="flex items-center justify-between px-4 py-3">
      <div class="flex items-center gap-3">
        <button
          type="button"
          data-back-system="true"
          class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-xs font-semibold text-slate-700 hover:bg-slate-50"
        >
          <span aria-hidden="true">&larr;</span>
          Retour
        </button>
        <h1 class="text-lg font-bold text-[#1E3A8A]"><%= headerTitle || "UNITECH ERP" %></h1>
      </div>
      <div><%- include("../partials/toast") %></div>
    </div>
  </header>
  <div class="grid min-h-[calc(100vh-57px)] grid-cols-1 lg:grid-cols-[260px_1fr]">
    <aside class="border-r border-slate-200 bg-white p-4">
      <%- include("../partials/sidebar", { activeNav: activeNav || "" }) %>
    </aside>
    <main class="p-4 lg:p-6">
      <%- include(contentPartial) %>
    </main>
  </div>
  <footer class="border-t border-slate-200 bg-white px-4 py-3 text-center text-xs text-slate-500">
    UNITECH ERP - SaaS scolaire
  </footer>
</body>
</html>
